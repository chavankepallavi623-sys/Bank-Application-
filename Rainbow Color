#include <iostream>
using namespace std;

int main()
{
    int choice;

    cout<<"1.Red 2.Orange 3.Yellow 4.Green 5.Blue 6.Indigo 7.Violet\n";
    cout<<"Enter choice: ";
    cin>>choice;

    switch(choice)
    {
        case 1: cout<<"Red"; break;
        case 2: cout<<"Orange"; break;
        case 3: cout<<"Yellow"; break;
        case 4: cout<<"Green"; break;
        case 5: cout<<"Blue"; break;
        case 6: cout<<"Indigo"; break;
        case 7: cout<<"Violet"; break;
        default: cout<<"Invalid";
    }

    return 0;
}