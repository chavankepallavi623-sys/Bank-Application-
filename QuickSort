#include<iostream.h>
#include<conio.h>

void quick(int a[], int l, int r)
{
if(l >= r)
return;

int i = l;  
int j = r;  
int pivot = a[l];  
int temp;  

while(i < j)  
{  
    while(a[i] <= pivot && i < r)  
        i++;  

    while(a[j] > pivot)  
        j--;  

    if(i < j)  
    {  
        temp = a[i];  
        a[i] = a[j];  
        a[j] = temp;  
    }  
}  

// Proper pivot placement  
a[l] = a[j];  
a[j] = pivot;  

quick(a, l, j-1);  
quick(a, j+1, r);

}

void main()
{
clrscr();

int a[10], n, i;  

cout<<"Enter size: ";  
cin>>n;  

cout<<"Enter elements:\n";  
for(i=0;i<n;i++)  
    cin>>a[i];  

quick(a,0,n-1);  

cout<<"Sorted array: ";  
for(i=0;i<n;i++)  
    cout<<a[i]<<" ";  

getch();

}
